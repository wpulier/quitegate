{
  "manifest_version": 2,
  "name": "QuietGate Helper",
  "description": "QuietGate browser helper for site tuning and browser rule updates.",
  "version": "0.1.12",
  "permissions": [
    "nativeMessaging",
    "activeTab",
    "storage",
    "webRequest",
    "webRequestBlocking",
    "http://*/*",
    "https://*/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "quietgate@willpulier.com",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "QuietGate"
  },
  "web_accessible_resources": ["blocked/*", "content/x-page.js", "rules/adult-domains.json"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://m.youtube.com/*"],
      "css": ["content/youtube.css"],
      "js": ["content/site-usage.js", "content/youtube.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*", "https://mobile.x.com/*"],
      "css": ["content/x.css"],
      "js": ["content/site-usage.js", "content/x.js", "content/platform-controls.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.instagram.com/*", "https://instagram.com/*"],
      "css": ["content/instagram.css"],
      "js": ["content/site-usage.js", "content/instagram.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.reddit.com/*", "https://old.reddit.com/*", "https://new.reddit.com/*"],
      "css": ["content/reddit.css"],
      "js": ["content/site-usage.js", "content/reddit.js", "content/platform-controls.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*",
        "https://x.com/*",
        "https://twitter.com/*",
        "https://mobile.x.com/*",
        "https://www.instagram.com/*",
        "https://instagram.com/*",
        "https://www.reddit.com/*",
        "https://old.reddit.com/*",
        "https://new.reddit.com/*"
      ],
      "js": ["content/web-classifier.js"],
      "run_at": "document_start"
    }
  ]
}
